#!/usr/bin/env bash
set -euo pipefail

remote="${1:-}"

# Mirror to GitHub only when pushing to the canonical GitLab remote.
if [ "$remote" != "origin" ]; then
  exit 0
fi

if ! git remote get-url github >/dev/null 2>&1; then
  echo "pre-push: github remote not configured; run scripts/setup-githooks.sh" >&2
  exit 0
fi

plan_file="$(mktemp)"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "${local_ref:-}" ]; then
    continue
  fi

  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    printf 'delete\t%s\n' "$remote_ref" >>"$plan_file"
  else
    printf 'push\t%s\t%s\n' "$local_ref" "$remote_ref" >>"$plan_file"
  fi
done

if [ ! -s "$plan_file" ]; then
  exit 0
fi

git_pid="$PPID"

(
  while kill -0 "$git_pid" 2>/dev/null; do
    sleep 0.2
  done

  while IFS=$'\t' read -r action arg1 arg2; do
    case "$action" in
      push)
        git push github "${arg1}:${arg2}" --quiet
        ;;
      delete)
        ref_name="${arg1#refs/heads/}"
        ref_name="${ref_name#refs/tags/}"
        git push github --delete "$ref_name" --quiet 2>/dev/null || true
        ;;
    esac
  done <"$plan_file"

  rm -f "$plan_file"
  echo "pre-push: mirrored to github"
) &

exit 0
